# =============================================================
# automaton-lifecycle 插件配置文件
# 使用方法：复制此文件为 .env，填入你的实际参数
#   cp .env.example .env
# =============================================================

# ─── Agent Hub 连接 ──────────────────────────────────────────
# Agent Hub 后端服务地址（本地部署默认为下方值）
AGENT_HUB_URL=http://127.0.0.1:8000

# Agent 的唯一 UUID（首次留空可自动注册；或手动在 Hub UI 创建后填入）
AGENT_ID=

# Agent 身份文件路径（可选）。若多个实例共享同一 workspace，请务必为每个实例指定独立路径，
# 否则会复用同一个 Hub 身份。
AGENT_IDENTITY_FILE=

# ─── 预算与生存层级 ──────────────────────────────────────────
# 每日最大 API 花费上限（美元）
DAILY_BUDGET_USD=5.0

# 花费达到以下比例时进入"低算力模式"（百分比）
LOW_COMPUTE_THRESHOLD_PCT=80

# 花费达到以下比例时进入"紧急告警模式"（百分比）
CRITICAL_THRESHOLD_PCT=95

# ─── 心跳控制 ────────────────────────────────────────────────
# 连续 N 次空闲心跳后，开始拉长心跳间隔
IDLE_TICKS_BEFORE_SLOWDOWN=3

# 空闲放缓时，心跳间隔放大倍数
IDLE_HEARTBEAT_MULTIPLIER=2

# ─── 模型降级 ────────────────────────────────────────────────
# 进入低算力模式时切换到的廉价模型（留空则不切换）
LOW_COMPUTE_MODEL=

# 自省（Soul Reflection）使用的模型（留空则与主模型相同）
SOUL_REFLECTION_MODEL=

# ─── 功能开关 ────────────────────────────────────────────────
# 是否启用远端记忆日志记录（true/false）
ENABLE_MEMORY_JOURNAL=true

# 是否启用 Soul.md 自动自省（true/false）
ENABLE_SOUL_REFLECTION=true
